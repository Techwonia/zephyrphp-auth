{
    "name": "zephyrphp/auth",
    "description": "Authentication module for ZephyrPHP - Session and JWT authentication",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "zephyrphp/framework": "^0.1|dev-main"
    },
    "autoload": {
        "psr-4": {
            "ZephyrPHP\\Auth\\": "src/"
        }
    },
    "extra": {
        "zephyr": {
            "module": "auth",
            "config": "config/auth.php",
            "dependencies": ["session"]
        }
    }
}
